# Base de données Postgres (Neon)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Mot de passe d'accès unique au site (les deux espaces Elomty/Didi partagent le même accès)
SITE_PASSWORD="change-moi"

# Secret utilisé pour signer le cookie de session (générer avec: openssl rand -base64 32)
NEXTAUTH_SECRET="change-moi"

# Clé pour chiffrer les secrets d'API stockés en base (générer avec: openssl rand -hex 32)
ENCRYPTION_KEY="change-moi"

# Les clés France Travail / Adzuna / Google CSE se saisissent directement
# dans l'onglet Réglages de chaque espace (stockées chiffrées en base, pas ici).

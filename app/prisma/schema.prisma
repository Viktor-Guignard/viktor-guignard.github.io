generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// "elomty" ou "didi" — les deux espaces, isolés par cette clé
model Profile {
  id            String   @id @default(cuid())
  workspace     String   @unique
  poste         String   @default("")
  localisation  String   @default("")
  experience    String   @default("")
  secteurs      String   @default("")
  updatedAt     DateTime @updatedAt
}

model Settings {
  id                      String   @id @default(cuid())
  workspace               String   @unique
  franceTravailClientId   String   @default("")
  franceTravailSecretEnc  String   @default("")
  adzunaAppId             String   @default("")
  adzunaAppKeyEnc         String   @default("")
  googleCseId             String   @default("")
  googleCseKeyEnc         String   @default("")
  hunterApiKeyEnc         String   @default("")
  gmailAddress            String   @default("")
  updatedAt               DateTime @updatedAt
}

model Offer {
  id           String   @id @default(cuid())
  workspace    String
  externalId   String
  titre        String
  entreprise   String
  lieu         String
  contact      String?
  contactGuessed Boolean @default(false)
  exigences    String
  source       String
  url          String?
  altStage     Boolean  @default(false)
  selected     Boolean  @default(true)
  // Marqué manuellement via le bouton "Postuler" — il n'existe aucun moyen fiable de
  // détecter automatiquement une candidature (pas d'envoi d'email ni d'intégration ATS) ;
  // on considère qu'un clic sur "Postuler" vaut candidature effective.
  applied      Boolean  @default(false)
  appliedAt    DateTime?
  createdAt    DateTime @default(now())

  @@unique([workspace, externalId])
  @@index([workspace])
}
